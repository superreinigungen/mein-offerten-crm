import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:provider/provider.dart';
import 'dart:html' as html;
import '../providers/app_provider.dart';
import '../models/cleaning_request.dart';
import '../models/quote.dart';
import '../utils/theme.dart';
import '../utils/formatters.dart';

/// Screen zum Erstellen/Bearbeiten einer Offerte
class CreateQuoteScreen extends StatefulWidget {
  final CleaningRequest request;
  final Quote? existingQuote;

  const CreateQuoteScreen({
    super.key,
    required this.request,
    this.existingQuote,
  });

  @override
  State<CreateQuoteScreen> createState() => _CreateQuoteScreenState();
}

class _CreateQuoteScreenState extends State<CreateQuoteScreen> {
  late TextEditingController _priceController;
  late TextEditingController _messageController;
  bool _isSending = false;
  bool _previewSeen = false;
  double _suggestedPrice = 0;

  @override
  void initState() {
    super.initState();
    _suggestedPrice = widget.request.calculateSuggestedPrice();
    
    _priceController = TextEditingController(
      text: widget.existingQuote?.price.toStringAsFixed(2) ?? 
            _suggestedPrice.toStringAsFixed(2),
    );
    _messageController = TextEditingController(
      text: widget.existingQuote?.customMessage ?? '',
    );
  }

  @override
  void dispose() {
    _priceController.dispose();
    _messageController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final isEditing = widget.existingQuote != null;
    final isAlreadySent = widget.existingQuote?.sentAt != null;

    // WENN BEREITS GESENDET: Zeige Nur-Ansicht-Modus
    if (isAlreadySent) {
      return _buildSentQuoteView(context);
    }

    return Scaffold(
      backgroundColor: AppTheme.background,
      appBar: AppBar(
        title: Text(isEditing ? 'Offerte bearbeiten' : 'Offerte erstellen'),
        actions: [
          if (isEditing && !isAlreadySent)
            TextButton(
              onPressed: _saveDraft,
              child: const Text(
                'Speichern',
                style: TextStyle(color: Colors.white),
              ),
            ),
        ],
      ),
      body: SingleChildScrollView(
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // Kunden-Info Header
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(20),
              decoration: BoxDecoration(
                color: Colors.white,
                boxShadow: [
                  BoxShadow(
                    color: Colors.black.withValues(alpha: 0.05),
                    blurRadius: 10,
                  ),
                ],
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(
                    children: [
                      CircleAvatar(
                        radius: 24,
                        backgroundColor: AppTheme.primaryLight.withValues(alpha: 0.2),
                        child: Text(
                          _getInitials(widget.request.customerName),
                          style: const TextStyle(
                            color: AppTheme.primaryDark,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                      ),
                      const SizedBox(width: 12),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: [
                            Text(
                              widget.request.customerName,
                              style: const TextStyle(
                                fontSize: 18,
                                fontWeight: FontWeight.bold,
                                color: AppTheme.textPrimary,
                              ),
                            ),
                            Text(
                              widget.request.address,
                              style: const TextStyle(
                                fontSize: 13,
                                color: AppTheme.textSecondary,
                              ),
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                  const SizedBox(height: 16),
                  // Quick Info
                  Wrap(
                    spacing: 16,
                    runSpacing: 8,
                    children: [
                      _QuickInfoChip(
                        icon: Icons.home,
                        label: Formatters.roomCount(widget.request.roomCount),
                      ),
                      _QuickInfoChip(
                        icon: Icons.square_foot,
                        label: widget.request.areaRange,
                      ),
                      _QuickInfoChip(
                        icon: Icons.calendar_today,
                        label: Formatters.date(widget.request.cleaningDate),
                      ),
                    ],
                  ),
                ],
              ),
            ),

            Padding(
              padding: const EdgeInsets.all(16),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  // Preisvorschlag
                  Card(
                    color: AppTheme.success.withValues(alpha: 0.1),
                    child: Padding(
                      padding: const EdgeInsets.all(16),
                      child: Row(
                        children: [
                          Container(
                            padding: const EdgeInsets.all(10),
                            decoration: BoxDecoration(
                              color: AppTheme.success.withValues(alpha: 0.2),
                              borderRadius: BorderRadius.circular(10),
                            ),
                            child: const Icon(
                              Icons.lightbulb_outline,
                              color: AppTheme.success,
                            ),
                          ),
                          const SizedBox(width: 12),
                          Expanded(
                            child: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: [
                                const Text(
                                  'Berechneter Richtpreis',
                                  style: TextStyle(
                                    fontSize: 12,
                                    color: AppTheme.textSecondary,
                                  ),
                                ),
                                Text(
                                  Formatters.price(_suggestedPrice),
                                  style: const TextStyle(
                                    fontSize: 24,
                                    fontWeight: FontWeight.bold,
                                    color: AppTheme.success,
                                  ),
                                ),
                              ],
                            ),
                          ),
                          OutlinedButton(
                            onPressed: () {
                              _priceController.text = _suggestedPrice.toStringAsFixed(2);
                            },
                            style: OutlinedButton.styleFrom(
                              foregroundColor: AppTheme.success,
                              side: const BorderSide(color: AppTheme.success),
                            ),
                            child: const Text('Übernehmen'),
                          ),
                        ],
                      ),
                    ),
                  ),

                  const SizedBox(height: 24),

                  // Preis-Eingabe
                  const Text(
                    'Dein Preis',
                    style: TextStyle(
                      fontSize: 16,
                      fontWeight: FontWeight.w600,
                      color: AppTheme.textPrimary,
                    ),
                  ),
                  const SizedBox(height: 8),
                  TextField(
                    controller: _priceController,
                    keyboardType: const TextInputType.numberWithOptions(decimal: true),
                    inputFormatters: [
                      FilteringTextInputFormatter.allow(RegExp(r'^\d+\.?\d{0,2}')),
                    ],
                    style: const TextStyle(
                      fontSize: 32,
                      fontWeight: FontWeight.bold,
                      color: AppTheme.primaryDark,
                    ),
                    decoration: InputDecoration(
                      prefixText: 'CHF ',
                      prefixStyle: const TextStyle(
                        fontSize: 32,
                        fontWeight: FontWeight.bold,
                        color: AppTheme.primaryDark,
                      ),
                      filled: true,
                      fillColor: Colors.white,
                      border: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(12),
                        borderSide: const BorderSide(color: AppTheme.cardBorder),
                      ),
                      focusedBorder: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(12),
                        borderSide: const BorderSide(color: AppTheme.primaryDark, width: 2),
                      ),
                    ),
                  ),

                  const SizedBox(height: 8),

                  // Schnell-Preise
                  Row(
                    children: [
                      _QuickPriceButton(
                        label: '-50',
                        onTap: () => _adjustPrice(-50),
                      ),
                      _QuickPriceButton(
                        label: '-20',
                        onTap: () => _adjustPrice(-20),
                      ),
                      _QuickPriceButton(
                        label: '+20',
                        onTap: () => _adjustPrice(20),
                      ),
                      _QuickPriceButton(
                        label: '+50',
                        onTap: () => _adjustPrice(50),
                      ),
                    ],
                  ),

                  const SizedBox(height: 24),

                  // Persoenliche Nachricht
                  const Text(
                    'Persönliche Nachricht (optional)',
                    style: TextStyle(
                      fontSize: 16,
                      fontWeight: FontWeight.w600,
                      color: AppTheme.textPrimary,
                    ),
                  ),
                  const SizedBox(height: 8),
                  TextField(
                    controller: _messageController,
                    maxLines: 3,
                    maxLength: 200,
                    decoration: InputDecoration(
                      hintText: 'z.B. "Inkl. Spezialreinigung für hartnäckige Verschmutzungen"',
                      hintStyle: const TextStyle(
                        color: AppTheme.textHint,
                        fontSize: 14,
                      ),
                      filled: true,
                      fillColor: Colors.white,
                      border: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(12),
                      ),
                    ),
                  ),

                  const SizedBox(height: 24),

                  // VORSCHAU BUTTON - NEU!
                  Container(
                    width: double.infinity,
                    padding: const EdgeInsets.all(16),
                    decoration: BoxDecoration(
                      color: Colors.white,
                      borderRadius: BorderRadius.circular(12),
                      border: Border.all(
                        color: _previewSeen ? AppTheme.success : AppTheme.info,
                        width: 2,
                      ),
                    ),
                    child: Column(
                      children: [
                        Row(
                          children: [
                            Container(
                              padding: const EdgeInsets.all(10),
                              decoration: BoxDecoration(
                                color: (_previewSeen ? AppTheme.success : AppTheme.info).withValues(alpha: 0.1),
                                borderRadius: BorderRadius.circular(10),
                              ),
                              child: Icon(
                                _previewSeen ? Icons.check_circle : Icons.preview,
                                color: _previewSeen ? AppTheme.success : AppTheme.info,
                              ),
                            ),
                            const SizedBox(width: 12),
                            Expanded(
                              child: Column(
                                crossAxisAlignment: CrossAxisAlignment.start,
                                children: [
                                  Text(
                                    _previewSeen ? 'Vorschau gesehen ✓' : 'Offerte-Vorschau',
                                    style: TextStyle(
                                      fontSize: 16,
                                      fontWeight: FontWeight.bold,
                                      color: _previewSeen ? AppTheme.success : AppTheme.textPrimary,
                                    ),
                                  ),
                                  Text(
                                    _previewSeen 
                                      ? 'Du kannst die Offerte jetzt senden'
                                      : 'Sieh dir die Offerte an, bevor du sie sendest',
                                    style: const TextStyle(
                                      fontSize: 12,
                                      color: AppTheme.textSecondary,
                                    ),
                                  ),
                                ],
                              ),
                            ),
                          ],
                        ),
                        const SizedBox(height: 12),
                        SizedBox(
                          width: double.infinity,
                          child: ElevatedButton.icon(
                            onPressed: _showOffertePreview,
                            icon: const Icon(Icons.visibility),
                            label: const Text('Vorschau öffnen'),
                            style: ElevatedButton.styleFrom(
                              backgroundColor: AppTheme.info,
                              foregroundColor: Colors.white,
                              padding: const EdgeInsets.symmetric(vertical: 12),
                            ),
                          ),
                        ),
                      ],
                    ),
                  ),

                  const SizedBox(height: 16),

                  // E-Mail Info (kompakter)
                  Card(
                    child: Padding(
                      padding: const EdgeInsets.all(12),
                      child: Row(
                        children: [
                          const Icon(Icons.email_outlined, color: AppTheme.textSecondary, size: 20),
                          const SizedBox(width: 8),
                          Expanded(
                            child: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: [
                                Text(
                                  'Wird gesendet an: ${widget.request.email}',
                                  style: const TextStyle(
                                    fontSize: 13,
                                    color: AppTheme.textSecondary,
                                  ),
                                ),
                                const Text(
                                  'Offerte ist 7 Tage gültig',
                                  style: TextStyle(
                                    fontSize: 11,
                                    color: AppTheme.textHint,
                                  ),
                                ),
                              ],
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),

                  const SizedBox(height: 100),
                ],
              ),
            ),
          ],
        ),
      ),
      
      // Senden Button - NEU: Zwei Buttons
      bottomNavigationBar: Container(
        padding: const EdgeInsets.all(16),
        decoration: BoxDecoration(
          color: Colors.white,
          boxShadow: [
            BoxShadow(
              color: Colors.black.withValues(alpha: 0.1),
              blurRadius: 10,
              offset: const Offset(0, -2),
            ),
          ],
        ),
        child: SafeArea(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              // Haupt-Button: Senden (nur aktiv wenn Vorschau gesehen)
              SizedBox(
                width: double.infinity,
                child: ElevatedButton.icon(
                  onPressed: _isSending 
                      ? null 
                      : (_previewSeen ? _sendQuote : _showPreviewFirst),
                  icon: _isSending
                      ? const SizedBox(
                          width: 20,
                          height: 20,
                          child: CircularProgressIndicator(
                            strokeWidth: 2,
                            valueColor: AlwaysStoppedAnimation<Color>(Colors.white),
                          ),
                        )
                      : Icon(_previewSeen ? Icons.send_rounded : Icons.preview),
                  label: Text(
                    _isSending 
                        ? 'Wird gesendet...' 
                        : (_previewSeen 
                            ? (isAlreadySent ? 'Erneut senden' : '▶ Offerte senden')
                            : '👁 Erst Vorschau ansehen'),
                    style: const TextStyle(fontSize: 16),
                  ),
                  style: ElevatedButton.styleFrom(
                    padding: const EdgeInsets.symmetric(vertical: 16),
                    backgroundColor: _previewSeen ? AppTheme.success : AppTheme.info,
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  // VORSCHAU ZUERST ANZEIGEN
  void _showPreviewFirst() {
    _showOffertePreview();
  }

  // OFFERTE VORSCHAU - Als Dialog anzeigen (funktioniert auf allen Geräten)
  void _showOffertePreview() {
    final price = double.tryParse(_priceController.text) ?? _suggestedPrice;
    
    showDialog(
      context: context,
      builder: (context) => _OffertePreviewDialog(
        request: widget.request,
        price: price,
        customMessage: _messageController.text,
        onConfirm: () {
          Navigator.pop(context);
          setState(() {
            _previewSeen = true;
          });
          ScaffoldMessenger.of(this.context).showSnackBar(
            const SnackBar(
              content: Row(
                children: [
                  Icon(Icons.check_circle, color: Colors.white),
                  SizedBox(width: 8),
                  Text('Vorschau bestätigt - Du kannst jetzt senden'),
                ],
              ),
              backgroundColor: AppTheme.success,
              duration: Duration(seconds: 2),
            ),
          );
        },
      ),
    );
  }

  // GENERIERE ECHTE HTML OFFERTE mit aktuellen Daten
  String _generateOfferteHtml(double price) {
    final request = widget.request;
    final createdDate = DateTime.now();
    final validUntilDate = createdDate.add(const Duration(days: 7));
    final customMessage = _messageController.text;
    
    return '''
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VORSCHAU - Offerte SR-2024-${request.id.substring(0, 4).toUpperCase()}</title>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f5f5f5; color: #333; line-height: 1.6; }
        .container { max-width: 800px; margin: 0 auto; background: white; box-shadow: 0 0 20px rgba(0,0,0,0.1); }
        
        /* Preview Banner */
        .preview-banner {
            background: linear-gradient(135deg, #ff9800, #f57c00);
            color: white;
            text-align: center;
            padding: 15px;
            font-size: 14px;
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .preview-banner span { display: block; font-size: 12px; font-weight: normal; opacity: 0.9; margin-top: 4px; }
        
        .header { background: linear-gradient(135deg, #1a237e, #0d47a1); color: white; padding: 30px 40px; }
        .header-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .logo { font-size: 28px; font-weight: 700; }
        .logo span { color: #64b5f6; }
        .contact-info { text-align: right; font-size: 13px; opacity: 0.9; }
        .contact-info a { color: white; text-decoration: none; }
        .hotline { font-size: 16px; font-weight: 600; margin-bottom: 5px; }
        
        .offerte-header { background: #e3f2fd; padding: 25px 40px; border-bottom: 3px solid #1976d2; }
        .offerte-header h1 { color: #1a237e; font-size: 22px; margin-bottom: 15px; }
        .offerte-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .meta-item { display: flex; flex-direction: column; }
        .meta-label { font-size: 11px; color: #666; text-transform: uppercase; }
        .meta-value { font-size: 15px; font-weight: 600; color: #1a237e; }
        
        .content { padding: 30px 40px; }
        .greeting { font-size: 17px; margin-bottom: 15px; }
        .intro-text { color: #555; margin-bottom: 25px; font-size: 14px; }
        
        .section { margin-bottom: 25px; }
        .section-title { font-size: 15px; font-weight: 600; color: #1a237e; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid #e0e0e0; display: flex; align-items: center; gap: 8px; }
        .section-title::before { content: ''; width: 4px; height: 18px; background: #1976d2; border-radius: 2px; }
        
        .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .detail-row { display: flex; padding: 8px 12px; background: #fafafa; border-radius: 6px; }
        .detail-label { width: 120px; color: #666; font-size: 13px; }
        .detail-value { font-weight: 500; color: #333; font-size: 13px; }
        
        .services-list { list-style: none; }
        .services-list li { padding: 8px 12px; background: #fafafa; margin-bottom: 6px; border-radius: 6px; display: flex; align-items: flex-start; gap: 10px; font-size: 13px; }
        .services-list li::before { content: '✓'; color: #4caf50; font-weight: bold; }
        
        .custom-message { background: #e3f2fd; border-left: 4px solid #1976d2; padding: 15px; margin: 20px 0; border-radius: 0 8px 8px 0; }
        .custom-message-label { font-size: 12px; color: #1565c0; font-weight: 600; margin-bottom: 5px; }
        .custom-message p { color: #1565c0; font-style: italic; }
        
        .price-box { background: linear-gradient(135deg, #e8f5e9, #c8e6c9); border-radius: 12px; padding: 25px; text-align: center; margin: 25px 0; border: 2px solid #4caf50; }
        .price-label { font-size: 13px; color: #2e7d32; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .price-amount { font-size: 42px; font-weight: 700; color: #1b5e20; }
        .price-currency { font-size: 20px; }
        .price-info { font-size: 12px; color: #388e3c; margin-top: 8px; }
        .valid-until { margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(46, 125, 50, 0.3); font-size: 12px; color: #666; }
        
        .conditions { background: #fafafa; padding: 15px; border-radius: 8px; margin: 20px 0; }
        .conditions h4 { color: #1a237e; margin-bottom: 8px; font-size: 14px; }
        .conditions ul { list-style: disc; margin-left: 20px; color: #555; font-size: 13px; }
        .conditions li { margin-bottom: 4px; }
        
        .action-section { background: linear-gradient(135deg, #1a237e, #0d47a1); padding: 35px 40px; text-align: center; }
        .action-title { color: white; font-size: 20px; margin-bottom: 25px; font-weight: 600; }
        .action-buttons { display: flex; justify-content: center; gap: 15px; flex-wrap: wrap; }
        .btn { padding: 16px 35px; border: none; border-radius: 10px; font-size: 16px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
        .btn-accept { background: linear-gradient(135deg, #4caf50, #43a047); color: white; }
        .btn-reject { background: linear-gradient(135deg, #f44336, #e53935); color: white; }
        .btn-thinking { background: linear-gradient(135deg, #ff9800, #fb8c00); color: white; }
        .action-note { color: rgba(255,255,255,0.8); font-size: 13px; margin-top: 20px; }
        .action-note a { color: #90caf9; text-decoration: none; }
        
        .footer { background: #1a237e; color: white; padding: 25px 40px; text-align: center; }
        .footer-contact { margin-bottom: 12px; font-size: 13px; }
        .footer-contact a { color: #90caf9; text-decoration: none; }
        .footer-address { font-size: 12px; opacity: 0.8; }
        .signature { margin-top: 20px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.2); }
        .signature-name { font-size: 16px; font-weight: 600; }
        .signature-title { font-size: 12px; opacity: 0.8; }
        
        @media (max-width: 600px) {
            .header, .content, .action-section, .footer { padding: 20px; }
            .header-top { flex-direction: column; gap: 15px; }
            .contact-info { text-align: left; }
            .offerte-meta, .details-grid { grid-template-columns: 1fr; }
            .price-amount { font-size: 32px; }
            .action-buttons { flex-direction: column; }
            .btn { width: 100%; justify-content: center; padding: 14px 20px; }
        }
        
        @media print { .preview-banner { display: none; } }
    </style>
</head>
<body>
    <!-- Preview Banner -->
    <div class="preview-banner">
        ⚠️ VORSCHAU - So sieht der Kunde die Offerte
        <span>Nach dem Senden wird diese Offerte an ${request.email} geschickt</span>
    </div>
    
    <div class="container">
        <header class="header">
            <div class="header-top">
                <div class="logo">Super<span>Reinigungen</span>.ch</div>
                <div class="contact-info">
                    <div class="hotline">Hotline: +41 44 544 20 04</div>
                    <div><a href="mailto:info@superreinigungen.ch">info@superreinigungen.ch</a></div>
                    <div><a href="https://www.superreinigungen.ch">www.superreinigungen.ch</a></div>
                </div>
            </div>
        </header>
        
        <div class="offerte-header">
            <h1>Offerte für Umzugsreinigung - SR-2024-${request.id.substring(0, 4).toUpperCase()}</h1>
            <div class="offerte-meta">
                <div class="meta-item">
                    <span class="meta-label">Erstellt am</span>
                    <span class="meta-value">${_formatDate(createdDate)}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Gültig bis</span>
                    <span class="meta-value">${_formatDate(validUntilDate)}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Kunde</span>
                    <span class="meta-value">${request.customerName}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Reinigungstermin</span>
                    <span class="meta-value">${_formatDate(request.cleaningDate)}</span>
                </div>
            </div>
        </div>
        
        <main class="content">
            <p class="greeting">Guten Tag <strong>${request.customerName.split(' ').first}</strong>,</p>
            <p class="intro-text">
                Vielen Dank für Ihre Anfrage. Wir freuen uns, Ihnen folgendes Angebot für die 
                Umzugsreinigung mit Abnahmegarantie unterbreiten zu können.
            </p>
            
            <div class="section">
                <h3 class="section-title">Objekt-Informationen</h3>
                <div class="details-grid">
                    <div class="detail-row">
                        <span class="detail-label">Adresse</span>
                        <span class="detail-value">${request.address}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Objekttyp</span>
                        <span class="detail-value">${request.objectType}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Zimmerzahl</span>
                        <span class="detail-value">${request.roomCount} Zimmer</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Fläche</span>
                        <span class="detail-value">${request.areaRange}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Kontakt</span>
                        <span class="detail-value">${request.phoneNumber}</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">E-Mail</span>
                        <span class="detail-value">${request.email}</span>
                    </div>
                </div>
            </div>
            
            <div class="section">
                <h3 class="section-title">Leistungsumfang</h3>
                <ul class="services-list">
                    <li>Komplette Endreinigung mit Abnahmegarantie</li>
                    <li>Küche inkl. Geräte (Backofen, Kühlschrank, Geschirrspüler)</li>
                    <li>Badezimmer/WC inkl. Entkalkung</li>
                    <li>Alle Räume inkl. Böden, Fenster, Rahmen</li>
                    <li>Türen, Schränke, Steckdosen, Lichtschalter</li>
                    <li>Balkon/Terrasse (falls vorhanden)</li>
                    ${request.additionalServices.isNotEmpty ? request.additionalServices.map((s) => '<li>${s.label}</li>').join('') : ''}
                </ul>
            </div>
            
            ${customMessage.isNotEmpty ? '''
            <div class="custom-message">
                <div class="custom-message-label">Persönliche Nachricht:</div>
                <p>$customMessage</p>
            </div>
            ''' : ''}
            
            <div class="price-box">
                <div class="price-label">Ihr Pauschalpreis</div>
                <div class="price-amount"><span class="price-currency">CHF</span> ${price.toStringAsFixed(2)}</div>
                <div class="price-info">Inkl. MwSt. • Keine versteckten Kosten • Mit Abnahmegarantie</div>
                <div class="valid-until">
                    Dieses Angebot ist gültig bis: <strong>${_formatDate(validUntilDate)}</strong>
                </div>
            </div>
            
            <div class="conditions">
                <h4>Konditionen</h4>
                <ul>
                    <li>Der Preis versteht sich als Pauschalpreis, inkl. MwSt.</li>
                    <li>Bezahlung auf Rechnung (7 Tage) oder bar bei Abgabe.</li>
                    <li>Kostenlose Nachreinigung bei berechtigten Beanstandungen.</li>
                    <li>Die Wohnung muss am Reinigungstag leer und besenrein sein.</li>
                </ul>
            </div>
        </main>
        
        <div class="action-section">
            <h2 class="action-title">Wie möchten Sie fortfahren?</h2>
            <div class="action-buttons">
                <a href="#" class="btn btn-accept" onclick="alert('VORSCHAU: Der Kunde würde hier die Offerte annehmen'); return false;">
                    ✓ Offerte annehmen
                </a>
                <a href="#" class="btn btn-thinking" onclick="alert('VORSCHAU: Der Kunde würde hier wählen: Ich überlege noch'); return false;">
                    🕐 Ich überlege noch
                </a>
                <a href="#" class="btn btn-reject" onclick="alert('VORSCHAU: Der Kunde würde hier die Offerte ablehnen'); return false;">
                    ✗ Offerte ablehnen
                </a>
            </div>
            <p class="action-note">
                Bei Fragen: <a href="tel:+41445442004">+41 44 544 20 04</a>
            </p>
        </div>
        
        <footer class="footer">
            <div class="footer-contact">
                Tel: <a href="tel:+41445442004">+41 44 544 20 04</a> • 
                <a href="mailto:info@superreinigungen.ch">info@superreinigungen.ch</a> • 
                <a href="https://www.superreinigungen.ch">www.superreinigungen.ch</a>
            </div>
            <div class="footer-address">
                SuperReinigungen.ch - Badenerstrasse 562 - CH-8048 Zürich
            </div>
            <div class="signature">
                <div class="signature-name">Freundliche Grüsse, Petrit Xhaferi</div>
                <div class="signature-title">Geschäftsführer / Ihr Ansprechpartner</div>
            </div>
        </footer>
    </div>
</body>
</html>
''';
  }

  String _formatDate(DateTime date) {
    const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 
                    'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
    return '${date.day}. ${months[date.month - 1]} ${date.year}';
  }

  // NUR-ANSICHT FÜR BEREITS GESENDETE OFFERTEN
  Widget _buildSentQuoteView(BuildContext context) {
    final quote = widget.existingQuote!;
    final request = widget.request;
    final daysLeft = quote.validUntil.difference(DateTime.now()).inDays;
    final isExpired = daysLeft < 0;
    
    return Scaffold(
      backgroundColor: AppTheme.background,
      appBar: AppBar(
        title: const Text('Gesendete Offerte'),
        backgroundColor: AppTheme.info,
        actions: [
          IconButton(
            icon: const Icon(Icons.open_in_new),
            onPressed: () => _showOffertePreviewSent(),
            tooltip: 'In neuem Tab öffnen',
          ),
        ],
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // Status Banner
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: isExpired ? AppTheme.error.withValues(alpha: 0.1) : AppTheme.info.withValues(alpha: 0.1),
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: isExpired ? AppTheme.error : AppTheme.info),
              ),
              child: Row(
                children: [
                  Icon(
                    isExpired ? Icons.warning : Icons.check_circle,
                    color: isExpired ? AppTheme.error : AppTheme.info,
                    size: 32,
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          isExpired ? '⚠️ Offerte abgelaufen' : '✅ Offerte gesendet',
                          style: TextStyle(
                            fontWeight: FontWeight.bold,
                            fontSize: 16,
                            color: isExpired ? AppTheme.error : AppTheme.info,
                          ),
                        ),
                        Text(
                          isExpired 
                            ? 'Am ${_formatDate(quote.sentAt!)} gesendet, seit ${-daysLeft} Tagen abgelaufen'
                            : 'Am ${_formatDate(quote.sentAt!)} gesendet, noch $daysLeft Tage gültig',
                          style: TextStyle(fontSize: 13, color: isExpired ? AppTheme.error : AppTheme.textSecondary),
                        ),
                      ],
                    ),
                  ),
                ],
              ),
            ),
            
            const SizedBox(height: 20),
            
            // Kunde
            Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Row(
                  children: [
                    CircleAvatar(
                      radius: 24,
                      backgroundColor: AppTheme.primaryLight.withValues(alpha: 0.2),
                      child: Text(
                        _getInitials(request.customerName),
                        style: const TextStyle(color: AppTheme.primaryDark, fontWeight: FontWeight.bold),
                      ),
                    ),
                    const SizedBox(width: 12),
                    Expanded(
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          Text(request.customerName, style: const TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
                          Text(request.email, style: const TextStyle(fontSize: 13, color: AppTheme.textSecondary)),
                          Text(request.phoneNumber, style: const TextStyle(fontSize: 13, color: AppTheme.textSecondary)),
                        ],
                      ),
                    ),
                  ],
                ),
              ),
            ),
            
            const SizedBox(height: 16),
            
            // Offerten-Details
            Card(
              child: Padding(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Row(
                      children: [
                        Icon(Icons.receipt_long, color: AppTheme.primaryDark),
                        SizedBox(width: 8),
                        Text('Offerten-Details', style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold)),
                      ],
                    ),
                    const Divider(height: 24),
                    _buildInfoRow('Preis', 'CHF ${quote.price.toStringAsFixed(2)}', isBold: true),
                    _buildInfoRow('Gesendet am', _formatDate(quote.sentAt!)),
                    _buildInfoRow('Gültig bis', '${_formatDate(quote.validUntil)} ${isExpired ? "(ABGELAUFEN)" : ""}'),
                    _buildInfoRow('Objekt', request.address),
                    _buildInfoRow('Zimmer', '${request.roomCount}'),
                    _buildInfoRow('Fläche', request.areaRange),
