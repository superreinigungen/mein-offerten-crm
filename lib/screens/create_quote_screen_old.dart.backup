/// Quick Price Adjustment Button
class _QuickPriceButton extends StatelessWidget {
  final String label;
  final VoidCallback onTap;

  const _QuickPriceButton({
    required this.label,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    final isNegative = label.startsWith('-');
    
    return Expanded(
      child: Padding(
        padding: const EdgeInsets.symmetric(horizontal: 4),
        child: OutlinedButton(
          onPressed: onTap,
          style: OutlinedButton.styleFrom(
            foregroundColor: isNegative ? AppTheme.error : AppTheme.success,
            side: BorderSide(
              color: isNegative ? AppTheme.error : AppTheme.success,
            ),
            padding: const EdgeInsets.symmetric(vertical: 8),
          ),
          child: Text(label),
        ),
      ),
    );
  }
}

